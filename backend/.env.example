# ============================================================
# GoatRaw - Complete Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── App ───────────────────────────────────────────────────────
SECRET_KEY=replace-with-64-char-random-string
DEBUG=false
FRONTEND_URL=https://app.goatraw.ai

# ── Database (Supabase) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_KEY=[your-supabase-anon-key]

# ── Redis (Upstash) ───────────────────────────────────────────
REDIS_URL=rediss://:[PASSWORD]@[HOST].upstash.io:6379

# ── LLM Providers (get at least GROQ which is free) ──────────
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...           # Optional, for smart routing
TOGETHER_API_KEY=...            # Optional, fallback

# ── Channels ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...          # From @BotFather
SLACK_BOT_TOKEN=xoxb-...        # From Slack App Dashboard
WHATSAPP_ACCESS_TOKEN=...       # From Meta Developer Portal
WHATSAPP_PHONE_NUMBER_ID=...    # From Meta Developer Portal
WHATSAPP_VERIFY_TOKEN=goatraw-verify-secret
DISCORD_BOT_TOKEN=...           # From Discord Developer Portal

# ── Search (optional, enhances web search quality) ───────────
SERPAPI_KEY=...                 # From serpapi.com (~$50/mo)

# ── Browser Tool (optional, enables JS page rendering) ───────
ENABLE_BROWSER_TOOL=false       # Set true only if playwright installed
